      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Decision Quality & Policy Drift",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "### Policy Behavior Monitoring\nDetects silent policy regressions via acceptance/deny distribution, failed-standard mix, and abrupt deny-rate shifts.\n\nUse alongside OPA performance board to separate behavior changes from engine latency issues."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Accept Ratio (1h)",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 3
      },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.6
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min(sum(increase(firewall_decisions_total[1h])) - sum(increase(firewall_decisions_deny[1h])), 0) / clamp_min(sum(increase(firewall_decisions_total[1h])), 1)",
          "legendFormat": "accept ratio"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Deny Ratio (1h)",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 3
      },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.2
              },
              {
                "color": "red",
                "value": 0.4
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(firewall_decisions_deny[1h])) / clamp_min(sum(increase(firewall_decisions_total[1h])), 1)",
          "legendFormat": "deny ratio"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Deny Rate Shift (5m vs 6h avg)",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 3
      },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min(firewall:deny_rate_5m - avg_over_time(firewall:deny_rate_5m[6h]), 0)",
          "legendFormat": "deny shift"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Accept vs Deny Volume (5m increase)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "datasource": "Prometheus",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min(sum(increase(firewall_decisions_total[5m])) - sum(increase(firewall_decisions_deny[5m])), 0)",
          "legendFormat": "accepted"
        },
        {
          "refId": "B",
          "expr": "sum(increase(firewall_decisions_deny[5m]))",
          "legendFormat": "denied"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Failed Standards Mix (5m increase)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "datasource": "Prometheus",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(firewall_failed_standard_ms_nfr_total[5m])",
          "legendFormat": "M&S NFR"
        },
        {
          "refId": "B",
          "expr": "increase(firewall_failed_standard_iso_27001_total[5m])",
          "legendFormat": "ISO 27001"
        },
        {
          "refId": "C",
          "expr": "increase(firewall_failed_standard_cis_v81_total[5m])",
          "legendFormat": "CIS v8.1"
        },
        {
          "refId": "D",
          "expr": "increase(firewall_failed_standard_pci_dss_total[5m])",
          "legendFormat": "PCI-DSS"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Risk Level Distribution (Loki, 1h)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (risk_level) (count_over_time({job=\"systemd-journal\",unit=\"opa-api-8001.service\",event=\"decision.recorded\",risk_level=~\"LOW|MEDIUM|HIGH|CRITICAL\",request_id!~\"test-.*\"}[1h]))",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Policy/Decision Error Logs (Loki)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"systemd-journal\",unit=\"opa-api-8001.service\"} |~ \"(?i)(policy|decision|violation|failed standard|opa unavailable|error|exception)\" | json | request_id !~ \"^test-\"",
          "queryType": "range"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
