      {
        "name": "Service Restarts",
        "datasource": "Prometheus",
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "expr": "changes(process_start_time_seconds{job=~\"firewall-api-slo|firewall-api-alerts|firewall-api-roi|prometheus|node-exporter\"}[1m]) > 0",
        "titleFormat": "Restart",
        "textFormat": "Restart detected for {{job}}",
        "type": "tags"
      }
