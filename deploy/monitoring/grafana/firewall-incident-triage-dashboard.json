    {
      "id": 8,
      "type": "logs",
      "title": "API Error Logs (Loki)",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"systemd-journal\",unit=\"opa-api-8001.service\"} |~ \"(?i)(error|exception|timeout|failed|circuit|unavailable)\" | json | request_id !~ \"^test-\"",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Canary Probes (pass=1)",
      "datasource": "Prometheus",
      "description": "1=both probes match expected verdict (known-good ACCEPTABLE, known-deny DENY). 0=policy regression.",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(firewall_canary_pass)",
          "legendFormat": "canary pass"
        },
        {
          "refId": "B",
          "expr": "sum(increase(firewall_canary_errors_total[10m]))",
          "legendFormat": "errors (10m)"
        }
      ]
    },
