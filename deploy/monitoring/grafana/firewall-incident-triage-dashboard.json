    {
      "id": 7,
      "type": "stat",
      "title": "API Error Rate (5m)",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 3
      },
      "datasource": "Prometheus",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
