          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, mode) (rate(firewall_opa_request_latency_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p99 {{mode}}"
        }
      ]
    },
