            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (increase(firewall_opa_requests_total[10m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
